# AI OS Personal - Environment Variables
# Skopiuj ten plik do .env i uzupełnij wartości

# Gemini API
GEMINI_API_KEY=twoj_klucz_tutaj
GEMINI_MODEL=gemini-1.5-pro

# Ścieżki do plików kontekstowych (relatywne do głównego folderu projektu)
GHOST_PATH=_ZESPOL/ghost.md
PERSONA_PATH=_KONTEKST/persona.md
OFERTA_PATH=_KONTEKST/oferta.md
CONTENTMACHINE_PATH=_ZESPOL/contentmachine.md
INDEX_PATH=MARKETING/05_PUBLIKACJE/INDEX_POSTOW.md

# Quality Loop - parametry
QUALITY_THRESHOLD=95
MAX_ITERATIONS=10
UNIQUENESS_DAYS=30

# Redis (Background Mode)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email notifications (opcjonalne)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=twoj_email@gmail.com
SMTP_PASSWORD=twoje_haslo_aplikacji
NOTIFICATION_EMAIL=twoj_email@gmail.com

# Slack notifications (opcjonalne)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
